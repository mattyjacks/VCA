# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# GiveGigs control-plane integration
# Keep this pointed at your GiveGigs deployment (or local dev URL)
GIVEGIGS_CONTROL_PLANE_URL=https://givegigs.com

# Optional but recommended for ecosystem admin-aware responses
# Must match GIVEGIGS_CONTROL_PLANE_INTEGRATION_KEY in GiveGigs env
GIVEGIGS_CONTROL_PLANE_INTEGRATION_KEY=replace-with-long-shared-secret
